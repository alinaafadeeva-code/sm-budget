# Скопируй этот файл в secrets.toml и заполни своими данными
# secrets.toml НЕ должен попасть в git (он уже в .gitignore)

spreadsheet_id = "ВОТ_СЮДА_ID_ТАБЛИЦЫ_ИЗ_ССЫЛКИ"

[gcp_service_account]
type = "service_account"
project_id = "твой-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "бюджет@твой-project-id.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
